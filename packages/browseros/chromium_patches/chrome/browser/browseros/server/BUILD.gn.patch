diff --git a/chrome/browser/browseros/server/BUILD.gn b/chrome/browser/browseros/server/BUILD.gn
new file mode 100644
index 0000000000000..0000000000000000000000000000000000000000
--- /dev/null
+++ b/chrome/browser/browseros/server/BUILD.gn
@@ -0,0 +1,137 @@
+# Copyright 2024 The Chromium Authors
+# Use of this source code is governed by a BSD-style license that can be
+# found in the LICENSE file.
+
+_browseros_binary_name = "browseros_server"
+if (is_win) {
+  _browseros_binary_name += ".exe"
+}
+
+source_set("server") {
+  sources = [
+    "browseros_appcast_parser.cc",
+    "browseros_appcast_parser.h",
+    "browseros_server_config.cc",
+    "browseros_server_config.h",
+    "browseros_server_constants.h",
+    "browseros_server_manager.cc",
+    "browseros_server_manager.h",
+    "browseros_server_prefs.cc",
+    "browseros_server_prefs.h",
+    "browseros_server_proxy.cc",
+    "browseros_server_proxy.h",
+    "browseros_server_updater.cc",
+    "browseros_server_updater.h",
+    "browseros_server_utils.cc",
+    "browseros_server_utils.h",
+    "health_checker.h",
+    "health_checker_impl.cc",
+    "health_checker_impl.h",
+    "process_controller.h",
+    "process_controller_impl.cc",
+    "process_controller_impl.h",
+    "server_state_store.h",
+    "server_state_store_impl.cc",
+    "server_state_store_impl.h",
+    "server_updater.h",
+  ]
+
+  deps = [
+    "//base",
+    "//chrome/browser:browser_process",
+    "//chrome/browser/browseros/metrics",
+    "//chrome/common",
+    "//components/prefs",
+    "//content/public/browser",
+    "//crypto",
+    "//net",
+    "//services/network/public/cpp",
+    "//services/network/public/mojom",
+    "//third_party/boringssl",
+    "//third_party/libxml:xml_reader",
+    "//third_party/zlib/google:zip",
+  ]
+}
+
+source_set("test_support") {
+  testonly = true
+  sources = [
+    "test/mock_health_checker.h",
+    "test/mock_implementations.cc",
+    "test/mock_process_controller.h",
+    "test/mock_server_state_store.h",
+    "test/mock_server_updater.h",
+  ]
+
+  deps = [
+    ":server",
+    "//base",
+    "//testing/gmock",
+  ]
+}
+
+source_set("unit_tests") {
+  testonly = true
+  sources = [
+    "browseros_appcast_parser_unittest.cc",
+    "browseros_server_manager_unittest.cc",
+    "browseros_server_utils_unittest.cc",
+  ]
+
+  deps = [
+    ":server",
+    ":test_support",
+    "//base",
+    "//base/test:test_support",
+    "//components/prefs:test_support",
+    "//net",
+    "//testing/gmock",
+    "//testing/gtest",
+  ]
+}
+
+action("generate_server_resources") {
+  script = "generate_server_resources.py"
+  outputs = [
+    "$target_gen_dir/browseros_resources/bin/${_browseros_binary_name}",
+    "$target_gen_dir/browseros_resources/bin/codex",
+    "$target_gen_dir/browseros_resources/bin/claude",
+  ]
+  args = [
+    rebase_path("$target_gen_dir/browseros_resources", root_build_dir),
+    _browseros_binary_name,
+  ]
+}
+
+if (is_mac) {
+  import("//build/config/apple/symbols.gni")
+  import("//build/config/mac/mac_sdk.gni")
+
+  bundle_data("browseros_resources_bundle") {
+    sources = [
+      "$target_gen_dir/browseros_resources/bin/${_browseros_binary_name}",
+      "$target_gen_dir/browseros_resources/bin/codex",
+      "$target_gen_dir/browseros_resources/bin/claude",
+    ]
+    outputs = [ "{{bundle_resources_dir}}/BrowserOSServer/default/bin/{{source_file_part}}" ]
+    deps = [ ":generate_server_resources" ]
+  }
+} else {
+  copy("browseros_resources_copy") {
+    sources = [
+      "$target_gen_dir/browseros_resources/bin/${_browseros_binary_name}",
+      "$target_gen_dir/browseros_resources/bin/codex",
+      "$target_gen_dir/browseros_resources/bin/claude",
+    ]
+    outputs = [ "$root_out_dir/BrowserOSServer/default/bin/{{source_file_part}}" ]
+    deps = [ ":generate_server_resources" ]
+  }
+}
+
+group("browseros_server_resources") {
+  if (is_mac) {
+    deps = [ ":browseros_resources_bundle" ]
+  } else {
+    deps = [ ":browseros_resources_copy" ]
+  }
+}
